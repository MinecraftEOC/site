{
    "name": "nuxt-template",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "author": "undef1ned-dev",
    "scripts": {
        "build": "nuxt build",
        "dev": "nuxt dev",
        "generate": "nuxt generate",
        "preview": "nuxt preview",
        "postinstall": "prisma generate && nuxt prepare",
        "test:run": "vitest run",
        "test:watch": "vitest",
        "el:check": "npx eslint .",
        "sl:check": "npx stylelint \"**/*.{scss,vue}\"",
        "lint:check": "npm run el:check && npm run sl:check",
        "el:fix": "npx eslint . --fix",
        "sl:fix": "npx stylelint \"**/*.{scss,vue}\" --fix",
        "lint:fix": "npm run el:fix && npm run sl:fix",
        "db:migrate": "prisma migrate dev",
        "db:deploy": "prisma migrate deploy",
        "db:studio": "prisma studio",
        "db:generate": "prisma generate"
    },
    "dependencies": {
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "nuxt": "4.4.8",
        "pg": "^8.22.0",
        "pinia": "3.0.4",
        "vue": "3.5.39"
    },
    "devDependencies": {
        "@antfu/eslint-config": "^9.1.0",
        "@nuxt/eslint": "1.16.0",
        "@pinia/nuxt": "0.11.3",
        "postcss-html": "^1.8.1",
        "prisma": "^7.8.0",
        "sass-embedded": "^1.100.0",
        "stylelint-config-hudochenkov": "^13.0.2"
    }
}
