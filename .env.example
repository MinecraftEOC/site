# --- PostgreSQL (используется и docker-compose, и Prisma) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=eoc
POSTGRES_PORT=5432

# DATABASE_URL должен совпадать со значениями POSTGRES_* выше
DATABASE_URL="postgresql://admin:admin@localhost:5432/eoc"

# --- Discord бот-плагин ---
NUXT_DISCORD_BOT_TOKEN=
NUXT_DISCORD_CLIENT_ID=
NUXT_DISCORD_GUILD_ID=
NUXT_DISCORD_CHANNEL_ID=
