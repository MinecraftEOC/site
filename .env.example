# --- PostgreSQL (используется и docker-compose, и Prisma) ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
POSTGRES_DB=eoc
POSTGRES_PORT=5432

# DATABASE_URL должен совпадать со значениями POSTGRES_* выше
DATABASE_URL="postgresql://admin:admin@localhost:5432/eoc"

# --- Discord бот-плагин ---
NUXT_DISCORD_BOT_TOKEN=
NUXT_DISCORD_CLIENT_ID=
NUXT_DISCORD_GUILD_ID=
NUXT_DISCORD_CHANNEL_ID=

# --- Server-to-server токен для ручек /api/server/* ---
# Общий секрет: тот же токен пропиши в env сервера Minecraft,
# он подставляется в заголовок Authorization: Bearer <token>.
NUXT_SERVER_API_TOKEN=
